% ──────────────────────────────────────────────────────────────────────────
% MANUAL PUBLICATIONS
%
% Add entries here for anything that won't show up via ORCID/Crossref:
%   - University-internal reports without a DOI
%   - Book chapters not yet registered
%   - Anything you want on the site before it has a DOI
%
% These entries are combined with the auto-synced ORCID entries into
% the top-level `publications.bib`, which Hugo Blox converts into
% publication pages. Use a stable, unique BibTeX key for each entry
% (e.g. lastname_year_keyword) so the generated page doesn't get
% recreated under a different folder name later.
% ──────────────────────────────────────────────────────────────────────────

% Example:
% @incollection{meixner_2026_examplechapter,
%   title     = {Example Book Chapter Title},
%   author    = {Meixner, Benedikt and Sperlich, Billy},
%   booktitle = {Example Book Title},
%   year      = {2026},
%   publisher = {Springer}
% }
